# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
# Required — supabase.ts throws at startup if this is missing.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (legacy JWT) or publishable key — safe to expose client-side.
# Required — supabase.ts throws at startup if this is missing.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL of the ADsentry FastAPI backend. Defaults to http://localhost:8000
# if unset.
NEXT_PUBLIC_API_URL=
