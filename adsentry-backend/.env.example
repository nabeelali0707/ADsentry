# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase project ref/ID (found in Project Settings > General)
SUPABASE_PROJECT_ID=

# Supabase publishable (sb_publishable_...) key — safe for client-side use
SUPABASE_PUBLISHABLE_KEY=

# Supabase service_role secret key — server-side only, bypasses RLS.
# Get it from Project Settings > API > service_role. Never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase anon (legacy JWT) key — used for verifying user JWTs server-side
SUPABASE_ANON_KEY=

# Groq API key for AI summary generation (console.groq.com)
GROQ_API_KEY=

# Postgres connection string used by db/apply_migrations.py (pooled connection)
DATABASE_URL=

# Direct (non-pooled) Postgres connection string, used for migrations that need it
DIRECT_URL=

# Comma-separated list of allowed CORS origins for the frontend, e.g.
# CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]
# Defaults to ["*"] (permissive) if unset — tighten for production.
CORS_ORIGINS=

# Comma-separated list of allowed Host headers for TrustedHostMiddleware, e.g.
# TRUSTED_HOSTS=your-app.onrender.com,your-app.vercel.app
# Defaults to a permissive dev list (including "*") if unset — tighten for production.
TRUSTED_HOSTS=

# Postgres connection string Dejavu's own fingerprinting engine uses to store
# its self-managed tables (songs/fingerprints, renamed to dejavu_songs/
# dejavu_fingerprints — see db/migrations/0003_dejavu_tables.sql). The same
# Supabase Postgres connection string as DATABASE_URL is fine to reuse.
DEJAVU_DATABASE_URL=
